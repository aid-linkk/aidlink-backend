<!-- AidLink Email Button Partial -->
<!-- Usage: {{> button link="https://..." label="View Details" }} -->
<table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin: 16px 0;">
  <tr>
    <td align="center" style="background-color: #1f7a5a; border-radius: 6px;">
      <a
        href="{{link}}"
        target="_blank"
        rel="noopener noreferrer"
        style="display: inline-block; padding: 14px 32px; color: #ffffff; font-size: 16px; font-weight: 600; text-decoration: none; border-radius: 6px; background-color: #1f7a5a;"
      >
        {{label}}
      </a>
    </td>
  </tr>
</table>
