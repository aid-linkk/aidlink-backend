<!-- Campaign Update Email Template -->
{{> greeting name=userName fallback="Supporter"}}

<p style="margin: 0 0 16px 0; font-size: 16px; color: #1f7a5a; font-weight: 600;">
  Campaign Update: {{campaignTitle}}
</p>

<p style="margin: 0 0 12px 0; color: #444; line-height: 1.6;">
  {{updateSummary}}
</p>

{{#if authorName}}
  <p style="margin: 0 0 6px 0; color: #888; font-size: 13px;">
    Posted by {{authorName}}{{#if postedDate}} on {{formatDate postedDate}}{{/if}}
  </p>
{{/if}}

{{#if fullUpdateLink}}
  <p style="margin: 8px 0 0 0;">
    <a href="{{fullUpdateLink}}" style="color: #1f7a5a; font-weight: 600;">
      Read the full update &rarr;
    </a>
  </p>
{{/if}}
