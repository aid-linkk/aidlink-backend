// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

// ============================================
// USER & AUTHENTICATION
// ============================================

enum Role {
  ADMIN
  ORGANIZATION
  DONOR
  BENEFICIARY
  VERIFIER
  AUDITOR
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  REJECTED
  DELETED
}

model User {
  id                  String     @id @default(cuid())
  email               String     @unique
  username            String?    @unique
  passwordHash        String?
  walletAddress       String?    @unique
  role                Role       @default(DONOR)
  status              UserStatus @default(PENDING_VERIFICATION)
  emailVerified       Boolean    @default(false)
  verificationToken   String?    @unique
  verificationExpiry  DateTime?
  failedVerifyAttempts Int       @default(0)
  lastLogin           DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  // Relations
  sessions                Session[]
  organizations           Organization?
  beneficiary             Beneficiary?
  donations               Donation[]
  campaigns               Campaign[]
  auditLogs               AuditLog[]
  notifications           Notification[]
  kycSubmissions          KYCSubmission[]
  pledges                 Pledge[]
  donorCredits            DonorCredit[]
  taxReceipts             TaxReceipt[]
  receiptBatchJobs        ReceiptBatchJob[]
  emailPreference         EmailPreference?
  emailVerificationTokens EmailVerificationToken[]

  @@index([email])
  @@index([walletAddress])
  @@index([role])
  @@index([status])
}

model VerificationLog {
  id         String   @id @default(cuid())
  userId     String
  action     String   // 'SENT' | 'VERIFIED' | 'EXPIRED' | 'RESENT' | 'FAILED'
  tokenHash  String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  refreshToken String?  @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// ============================================
// ORGANIZATION
// ============================================

enum OrganizationStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum OrganizationVerificationStatus {
  UNVERIFIED
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
  SUSPENDED
  MORE_INFO_REQUESTED
}

enum BankAccountVerificationStatus {
  UNVERIFIED
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
  ARCHIVED
}

model Organization {
  id                 String             @id @default(cuid())
  userId             String             @unique
  name               String
  email              String?
  country            String?
  description        String?
  website            String?
  logo               String?
  registrationNumber String?
  taxId              String?
  representativeContact Json?
  address            Json?
  legalDocuments     Json?
  supportingMetadata Json?
  status             OrganizationStatus @default(PENDING)
  verificationStatus OrganizationVerificationStatus @default(UNVERIFIED)
  verificationRequestedAt DateTime?
  verifiedAt         DateTime?
  verificationNotes  String?            @db.Text
  deletedAt          DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns        Campaign[]
  bankAccounts     BankAccount[]
  verificationEvents OrganizationVerificationEvent[]
  taxReceipts      TaxReceipt[]
  receiptBatchJobs ReceiptBatchJob[]

  @@index([userId])
  @@index([status])
  @@index([verificationStatus])
  @@index([deletedAt])
}

model BankAccount {
  id                 String                        @id @default(cuid())
  organizationId     String
  accountHolderName  String?
  bankName           String
  accountNumber      String
  routingNumber      String
  routingCode        String?
  iban               String?
  accountType        String
  currency           String                        @default("USD")
  branchCode         String?
  country            String?
  verificationStatus BankAccountVerificationStatus @default(UNVERIFIED)
  verificationNotes  String?                       @db.Text
  verifiedAt         DateTime?
  archivedAt         DateTime?
  isPrimary          Boolean                       @default(false)
  metadata           Json?
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([verificationStatus])
  @@index([archivedAt])
}

model OrganizationVerificationEvent {
  id             String                       @id @default(cuid())
  organizationId String
  actorId        String?
  status         OrganizationVerificationStatus
  reason         String?                      @db.Text
  evidence       Json?
  metadata       Json?
  createdAt      DateTime                     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([actorId])
  @@index([status])
  @@index([createdAt])
}

// ============================================
// CAMPAIGN
// ============================================

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
  SUSPENDED
  PENDING_REVIEW
}

model Campaign {
  id                 String         @id @default(cuid())
  organizationId     String
  userId             String
  title              String
  description        String         @db.Text
  imageUrl           String?
  targetAmount       Decimal        @db.Decimal(20, 8)
  currentAmount      Decimal        @default(0) @db.Decimal(20, 8)
  startDate          DateTime
  endDate            DateTime?
  status             CampaignStatus @default(DRAFT)
  blockchainTxHash   String?        @unique
  contractAddress    String?
  suspendedAt        DateTime?
  suspensionMetadata Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  organization  Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
donations     Donation[]
  beneficiaries BeneficiaryAssignment[]
  distributions Distribution[]
  milestones    Milestone[]
  multipliers   Multiplier[]
  matchedFunds  MatchedFund[]
  suspensions   Suspension[]
  appeals       Appeal[]
  fraudReports  FraudReport[]
  pledges       Pledge[]

  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model Milestone {
  id                  String                       @id @default(cuid())
  campaignId          String
  title               String
  description         String                       @db.Text
  targetAmount        Decimal                      @db.Decimal(20, 8)
  achieved            Boolean                      @default(false)
  achievedAt          DateTime?
  order               Int
  verificationStatus  MilestoneVerificationStatus  @default(PENDING_SUBMISSION)
  currentSubmissionId String?
  currentReviewId     String?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  campaign    Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  submissions MilestoneSubmission[]

  @@index([campaignId])
  @@index([verificationStatus])
}

// ============================================
// MILESTONE VERIFICATION
// ============================================

enum MilestoneSubmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum ReviewDecision {
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum MilestoneVerificationStatus {
  PENDING_SUBMISSION
  SUBMITTED
  UNDER_REVIEW
  VERIFIED
  REJECTED
  ARCHIVED
}

enum MilestoneVerificationEvent {
  SUBMITTED
  REVIEW_STARTED
  REVISION_REQUESTED
  APPROVED
  REJECTED
  RESUBMITTED
}

model MilestoneSubmission {
  id              String                    @id @default(cuid())
  campaignId      String
  milestoneId     String
  organizationId  String
  description     String                    @db.Text
  evidenceUrls    String[]
  metricsData     Json                      @default("{}")
  status          MilestoneSubmissionStatus @default(DRAFT)
  submittedAt     DateTime?
  submissionNotes String?                   @db.Text
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  milestone Milestone                        @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  reviews   MilestoneReview[]
  history   MilestoneVerificationHistory[]

  @@index([milestoneId])
  @@index([campaignId])
  @@index([organizationId])
  @@index([status])
  @@index([submittedAt])
}

model MilestoneReview {
  id               String         @id @default(cuid())
  submissionId     String
  verifierId       String
  decision         ReviewDecision
  reason           String?        @db.Text
  verifierNotes    String?        @db.Text
  metricsConfirmed Json?
  impactSummary    String?        @db.Text
  reviewedAt       DateTime       @default(now())
  createdAt        DateTime       @default(now())

  submission MilestoneSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([verifierId])
  @@index([decision])
  @@index([reviewedAt])
}

model MilestoneVerificationHistory {
  id           String                     @id @default(cuid())
  submissionId String
  event        MilestoneVerificationEvent
  actor        String
  metadata     Json?
  timestamp    DateTime                   @default(now())

  submission MilestoneSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([event])
  @@index([timestamp])
}

// ============================================
// DONATION
// ============================================

enum DonationStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

model Donation {
  id                 String         @id @default(cuid())
  campaignId         String
  userId             String?
  amount             Decimal        @db.Decimal(20, 8)
  currency           String         @default("XLM")
  status             DonationStatus @default(PENDING)
  blockchainTxHash   String?        @unique
  fromWallet         String?
  toWallet           String?
  memo               String?
  isAnonymous        Boolean        @default(false)
  donorMessage       String?        @db.Text
  receiptGeneratedAt DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  campaign   Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  taxReceipt TaxReceipt?

  @@index([campaignId])
  @@index([userId])
  @@index([status])
  @@index([blockchainTxHash])
  @@index([createdAt])
}

// ============================================
// BENEFICIARY
// ============================================

enum BeneficiaryStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
  ACTIVE
}

model Beneficiary {
  id               String            @id @default(cuid())
  userId           String            @unique
  firstName        String
  lastName         String
  dateOfBirth      DateTime
  gender           String
  nationality      String
  idDocumentType   String
  idDocumentNumber String
  phoneNumber      String
  address          String            @db.Text
  city             String
  country          String
  coordinates      String? // JSON: {lat, lng}
  familySize       Int               @default(1)
  needsAssessment  String?           @db.Text
  needsCategory    String?
  status           BeneficiaryStatus @default(PENDING)
  verifiedAt       DateTime?
  verifiedBy       String?
  riskScore        Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments    BeneficiaryAssignment[]
  distributions  Distribution[]
  kycSubmissions KYCSubmission[]

  @@index([userId])
  @@index([status])
  @@index([country])
  @@index([city])
  @@index([riskScore])
  @@index([needsCategory])
  @@index([familySize])
  @@index([dateOfBirth])
  @@index([country, city])
  @@index([status, country])
  @@index([firstName(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([lastName(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([idDocumentNumber(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([phoneNumber(ops: raw("gin_trgm_ops"))], type: Gin)
}

model BeneficiaryAssignment {
  id              String   @id @default(cuid())
  campaignId      String
  beneficiaryId   String
  assignedAmount  Decimal  @default(0) @db.Decimal(20, 8)
  allocatedAmount Decimal  @default(0) @db.Decimal(20, 8)
  priority        Int      @default(0)
  notes           String?  @db.Text
  assignedAt      DateTime @default(now())
  assignedBy      String?

  campaign    Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  beneficiary Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)

  @@unique([campaignId, beneficiaryId])
  @@index([campaignId])
  @@index([beneficiaryId])
}

// ============================================
// DISTRIBUTION
// ============================================

enum DistributionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

enum DistributionMethod {
  CASH
  BANK_TRANSFER
  MOBILE_MONEY
  CRYPTO
  VOUCHER
  IN_KIND
}

model Distribution {
  id               String             @id @default(cuid())
  campaignId       String
  beneficiaryId    String
  amount           Decimal            @db.Decimal(20, 8)
  currency         String             @default("XLM")
  method           DistributionMethod
  status           DistributionStatus @default(PENDING)
  blockchainTxHash String?            @unique
  transactionRef   String?
  proofDocumentUrl String?
  notes            String?            @db.Text
  distributedAt    DateTime?
  distributedBy    String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  campaign    Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  beneficiary Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([beneficiaryId])
  @@index([status])
  @@index([distributedAt])
}

// ============================================
// KYC & VERIFICATION
// ============================================

enum KYCStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

model KYCSubmission {
  id                String    @id @default(cuid())
  userId            String
  beneficiaryId     String?
  submissionType    String // INDIVIDUAL, ORGANIZATION
  status            KYCStatus @default(PENDING)
  documentType      String
  documentUrl       String
  selfieUrl         String?
  additionalDocs    Json?
  reviewNotes       String?   @db.Text
  reviewedBy        String?
  reviewedAt        DateTime?
  expiresAt         DateTime?
  fraudScore        Int       @default(0)
  fraudSignals      Json?     // Array of { signal, severity, detail }
  fraudReason       String?   @db.Text
  ipAddress         String?
  userAgent         String?
  deviceFingerprint String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  beneficiary Beneficiary? @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([beneficiaryId])
  @@index([status])
  @@index([createdAt])
  @@index([ipAddress])
  @@index([deviceFingerprint])
}

// ============================================
// NOTIFICATION
// ============================================

enum NotificationType {
  DONATION_RECEIVED
  CAMPAIGN_UPDATE
  DISTRIBUTION_SENT
  KYC_APPROVED
  KYC_REJECTED
  ORGANIZATION_PROFILE_UPDATED
  ORGANIZATION_VERIFICATION_SUBMITTED
  ORGANIZATION_VERIFICATION_APPROVED
  ORGANIZATION_VERIFICATION_REJECTED
  ORGANIZATION_VERIFICATION_INFO_REQUESTED
  BANK_ACCOUNT_ADDED
  BANK_ACCOUNT_REVIEW_REQUIRED
  SYSTEM_ALERT
  SECURITY_ALERT
  CAMPAIGN_SUSPENDED
  CAMPAIGN_REINSTATED
  APPEAL_UPDATE
  MILESTONE_SUBMISSION_RECEIVED
  MILESTONE_APPROVED
  MILESTONE_REJECTED
  MILESTONE_REVISION_REQUESTED
  REFUND_FAILED
  REFUND_RECOVERED
  DISTRIBUTION_FAILED
  CAMPAIGN_SETTLEMENT
  DONOR_CREDIT_ISSUED
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

model Notification {
  id        String             @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String             @db.Text
  status    NotificationStatus @default(UNREAD)
  metadata  Json?
  sentVia   String[]           @default([])
  readAt    DateTime?
  createdAt DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

// ============================================
// EMAIL PREFERENCES & TEMPLATES
// ============================================

model EmailPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  categories        Json
  allEmailsDisabled Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailTemplate {
  id              String   @id @default(cuid())
  name            String
  version         String
  notificationId  String?
  description     String?
  renderedAt      DateTime @default(now())
  metadata        Json?

  @@index([name])
  @@index([version])
  @@index([renderedAt])
}

// ============================================
// BLOCKCHAIN
// ============================================

enum TransactionType {
  DONATION
  DISTRIBUTION
  CONTRACT_DEPLOYMENT
  CONTRACT_CALL
  FEE_PAYMENT
}

model BlockchainTransaction {
  id              String          @id @default(cuid())
  txHash          String          @unique
  type            TransactionType
  fromAddress     String?
  toAddress       String?
  amount          Decimal?        @db.Decimal(20, 8)
  currency        String?
  contractAddress String?
  functionName    String?
  parameters      Json?
  status          String          @default("PENDING")
  blockNumber     BigInt?
  timestamp       DateTime?
  indexed         Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([txHash])
  @@index([type])
  @@index([status])
  @@index([indexed])
  @@index([blockNumber])
}

model ContractEvent {
  id              String    @id @default(cuid())
  txHash          String
  contractAddress String
  eventName       String
  parameters      Json
  blockNumber     BigInt?
  timestamp       DateTime?
  processed       Boolean   @default(false)
  createdAt       DateTime  @default(now())

  @@index([txHash])
  @@index([contractAddress])
  @@index([eventName])
  @@index([processed])
}

// ============================================
// AUDIT & LOGGING
// ============================================

enum AuditAction {
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  LOGIN
  LOGOUT
  CAMPAIGN_CREATED
  CAMPAIGN_UPDATED
  CAMPAIGN_DELETED
  DONATION_MADE
  DISTRIBUTION_SENT
  KYC_SUBMITTED
  KYC_APPROVED
  KYC_REJECTED
  ORGANIZATION_CREATED
  ORGANIZATION_UPDATED
  ORGANIZATION_DELETED
  ORGANIZATION_VERIFICATION_SUBMITTED
  ORGANIZATION_VERIFICATION_APPROVED
  ORGANIZATION_VERIFICATION_REJECTED
  ORGANIZATION_VERIFICATION_INFO_REQUESTED
  BANK_ACCOUNT_CREATED
  BANK_ACCOUNT_UPDATED
  BANK_ACCOUNT_DELETED
  BANK_ACCOUNT_VERIFICATION_REQUESTED
  ROLE_CHANGED
  SETTINGS_UPDATED
  CAMPAIGN_SUSPENDED
  CAMPAIGN_REINSTATED
  APPEAL_SUBMITTED
  APPEAL_RESOLVED
  FRAUD_REPORTED
  MILESTONE_SUBMITTED
  MILESTONE_APPROVED
  MILESTONE_REJECTED
  MILESTONE_REVISION_REQUESTED
  RECOVERY_CASE_CREATED
  RECOVERY_RETRIED
  RECOVERY_SETTLED
  RECOVERY_MANUAL_OVERRIDE
  DONOR_CREDIT_ISSUED
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  entityType String
  entityId   String?
  changes    Json?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

// ============================================
// RECOVERY WORKFLOW
// ============================================

enum RecoveryCaseType {
  FAILED_REFUND
  FAILED_DISTRIBUTION
  CANCELLED_CAMPAIGN_FUNDS
}

enum RecoveryStatus {
  PENDING
  RETRYING
  RECOVERED
  FAILED_PERMANENTLY
  RECOVERY_REQUIRED
}

enum SettlementOption {
  REFUND_TO_DONOR
  TRANSFER_TO_CAMPAIGN
  RETAIN_IN_ESCROW
}

model RecoveryCase {
  id              String            @id @default(cuid())
  type            RecoveryCaseType
  status          RecoveryStatus    @default(PENDING)
  // linked entities (one of these will be set)
  donationId      String?
  distributionId  String?
  campaignId      String?
  // failure metadata
  failureReason   String?           @db.Text
  failureMetadata Json?
  // retry tracking
  retryCount      Int               @default(0)
  maxRetries      Int               @default(3)
  nextRetryAt     DateTime?
  lastRetriedAt   DateTime?
  // settlement
  settlementOption  SettlementOption?
  settlementNotes   String?         @db.Text
  settledAt         DateTime?
  settledBy         String?
  resolvedAt        DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  donorCredits    DonorCredit[]

  @@index([type])
  @@index([status])
  @@index([donationId])
  @@index([distributionId])
  @@index([campaignId])
  @@index([nextRetryAt])
  @@index([createdAt])
}

enum DonorCreditStatus {
  PENDING
  APPLIED
  EXPIRED
}

model DonorCredit {
  id             String            @id @default(cuid())
  userId         String
  recoveryCaseId String
  amount         Decimal           @db.Decimal(20, 8)
  currency       String            @default("XLM")
  status         DonorCreditStatus @default(PENDING)
  reason         String?           @db.Text
  appliedAt      DateTime?
  expiresAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  recoveryCase RecoveryCase @relation(fields: [recoveryCaseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([recoveryCaseId])
  @@index([status])
  @@index([createdAt])
}

// ============================================
// WEBHOOKS
// ============================================

enum WebhookEventType {
  DONATION_CONFIRMED
  DISTRIBUTION_COMPLETED
  CAMPAIGN_MILESTONE_REACHED
  KYC_STATUS_CHANGED
}

enum WebhookDeliveryStatus {
  PENDING
  SENT
  FAILED
  DISABLED
}

model WebhookSubscription {
  id          String    @id @default(cuid())
  name        String
  url         String
  secret      String
  events      WebhookEventType[]
  active      Boolean   @default(true)
  description String?   @db.Text
  createdBy   String
  lastSuccessAt DateTime?
  failureCount  Int     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  webhookEvents WebhookEvent[]

  @@index([active])
  @@index([createdBy])
}

model WebhookEvent {
  id             String               @id @default(cuid())
  webhookId      String
  eventType      WebhookEventType
  payload        Json
  status         WebhookDeliveryStatus @default(PENDING)
  attempts       Int                  @default(0)
  maxAttempts    Int                  @default(5)
  lastAttemptAt  DateTime?
  nextRetryAt    DateTime?
  responseCode   Int?
  responseBody   String?              @db.Text
  errorMessage   String?              @db.Text
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  webhook WebhookSubscription @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([eventType])
  @@index([status])
  @@index([nextRetryAt])
  @@index([createdAt])
}

// ============================================
// QUEUE JOBS
// ============================================

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  RETRYING
}

enum JobType {
  EMAIL_NOTIFICATION
  BLOCKCHAIN_INDEXING
  KYC_VERIFICATION
  DISTRIBUTION_PROCESSING
  REPORT_GENERATION
  CACHE_INVALIDATION
  ANALYTICS_HOURLY
  ANALYTICS_MONTHLY
  ANALYTICS_REALTIME
  ANALYTICS_TRENDING_REFRESH
}

enum WebhookDeliveryStatus {
  PENDING
  SENT
  FAILED
  DISABLED
}

model QueueJob {
  id          String    @id @default(cuid())
  type        JobType
  status      JobStatus @default(PENDING)
  payload     Json
  result      Json?
  error       String?
  priority    Int       @default(0)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

// ============================================
// WEBHOOKS
// ============================================

model WebhookSubscription {
  id          String   @id @default(cuid())
  name        String
  url         String
  secret      String
  events      String[]
  active      Boolean  @default(true)
  description String?  @db.Text
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deliveries WebhookEvent[]

  @@index([active])
  @@index([createdBy])
  @@index([createdAt])
}

model WebhookEvent {
  id              String                @id @default(cuid())
  webhookId       String
  eventType       String
  payload         Json
  status          WebhookDeliveryStatus @default(PENDING)
  attempts        Int                   @default(0)
  maxAttempts     Int                   @default(3)
  nextRetryAt     DateTime?
  lastAttemptAt   DateTime?
  sentAt          DateTime?
  responseCode    Int?
  responseBody    String?               @db.Text
  responseHeaders Json?
  errorMessage    String?               @db.Text
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  webhook WebhookSubscription @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  deliveryAttempts WebhookDeliveryAttempt[]

  @@index([webhookId])
  @@index([eventType])
  @@index([status])
  @@index([nextRetryAt])
  @@index([createdAt])
}

model WebhookDeliveryAttempt {
  id              String   @id @default(cuid())
  webhookEventId  String
  attemptNumber   Int
  responseCode    Int?
  responseBody    String?  @db.Text
  responseHeaders Json?
  errorMessage    String?  @db.Text
  createdAt       DateTime @default(now())

  webhookEvent WebhookEvent @relation(fields: [webhookEventId], references: [id], onDelete: Cascade)

  @@index([webhookEventId])
  @@index([createdAt])
}

// ============================================
// CAMPAIGN MODERATION
// ============================================

enum SuspensionSource {
  AUTO
  ADMIN
}

enum SuspensionReasonCode {
  LOW_VERIFICATION
  FRAUD_REPORTS
  POLICY_VIOLATION
  MANUAL_REVIEW
  OTHER
}

enum AppealStatus {
  OPEN
  UNDER_REVIEW
  APPROVED
  DENIED
}

enum FraudReportType {
  SCAM
  MISINFORMATION
  INAPPROPRIATE_CONTENT
  IMPERSONATION
  DUPLICATE
  OTHER
}

// Immutable record of every campaign suspension. Append-only: rows are never
// deleted, and a reinstatement is recorded by setting lifted* fields + active=false.
model Suspension {
  id         String               @id @default(cuid())
  campaignId String
  actorId    String? // null when raised by the system (AUTO)
  source     SuspensionSource
  reasonCode SuspensionReasonCode
  reasonText String?              @db.Text
  evidence   Json?
  active     Boolean              @default(true)
  liftedAt   DateTime?
  liftedBy   String?
  liftNotes  String?              @db.Text
  createdAt  DateTime             @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  appeals  Appeal[]

  @@index([campaignId])
  @@index([active])
  @@index([reasonCode])
  @@index([createdAt])
}

model Appeal {
  id              String       @id @default(cuid())
  suspensionId    String
  campaignId      String
  campaignOwnerId String
  message         String       @db.Text
  attachments     Json?
  status          AppealStatus @default(OPEN)
  adminNotes      String?      @db.Text
  resolvedBy      String?
  resolvedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  suspension Suspension @relation(fields: [suspensionId], references: [id], onDelete: Cascade)
  campaign   Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([suspensionId])
  @@index([campaignId])
  @@index([campaignOwnerId])
  @@index([status])
  @@index([createdAt])
}

model FraudReport {
  id         String          @id @default(cuid())
  campaignId String
  reporterId String? // null for anonymous reports
  type       FraudReportType
  details    String?         @db.Text
  createdAt  DateTime        @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([reporterId])
  @@index([createdAt])
}

// ─── Pledge System ───────────────────────────────────────────────────────────

enum PledgeType {
  ONE_OFF
  RECURRING
}

enum PledgeCadence {
  WEEKLY
  MONTHLY
}

enum PledgeStatus {
  ACTIVE
  PAUSED
  CANCELLED
  FAILED
  COMPLETED
}

enum PledgeAttemptStatus {
  PENDING
  SUCCESS
  FAILED
}

model Pledge {
  id             String        @id @default(uuid())
  donorId        String
  campaignId     String?
  amount         Decimal
  currency       String        @default("USD")
  type           PledgeType
  cadence        PledgeCadence?
  startDate      DateTime
  nextRunAt      DateTime?
  endDate        DateTime?
  status         PledgeStatus  @default(ACTIVE)
  idempotencyKey String?       @unique
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  donor     User       @relation(fields: [donorId], references: [id])
  campaign  Campaign?  @relation(fields: [campaignId], references: [id])
  attempts  PledgeAttempt[]

  @@index([donorId])
  @@index([status, nextRunAt])
  @@map("pledges")
}

model PledgeAttempt {
  id               String              @id @default(uuid())
  pledgeId         String
  attemptAt        DateTime            @default(now())
  status           PledgeAttemptStatus @default(PENDING)
  providerReference String?
  failureReason    String?
  retryCount       Int                 @default(0)
  metadata         Json?
  createdAt        DateTime            @default(now())

  pledge Pledge @relation(fields: [pledgeId], references: [id])

  @@index([pledgeId])
  @@index([status])
  @@map("pledge_attempts")
}

// ============================================
// TAX RECEIPTS
// ============================================

enum ReceiptEmailStatus {
  PENDING
  SENT
  BOUNCED
  FAILED
}

enum ReceiptBatchJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// One immutable tax receipt per confirmed donation. Metadata is retained
// permanently for audit; the underlying PDF file may be subject to a separate
// retention policy. `donationId` is unique so generation is idempotent.
model TaxReceipt {
  id                  String             @id @default(uuid())
  donationId          String             @unique
  donorId             String
  organizationId      String
  amount              Decimal            @db.Decimal(20, 8)
  currency            String
  donationDate        DateTime
  receiptNumber       String             @unique
  filePath            String
  fileUrl             String?
  region              String
  taxDeductible       Boolean            @default(false)
  templateVersion     String
  generatedAt         DateTime           @default(now())
  emailSentAt         DateTime?
  emailDeliveryStatus ReceiptEmailStatus @default(PENDING)
  metadata            Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  donation     Donation     @relation(fields: [donationId], references: [id], onDelete: Cascade)
  donor        User         @relation(fields: [donorId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([donorId])
  @@index([organizationId])
  @@index([emailDeliveryStatus])
  @@index([donationDate])
  @@index([createdAt])
}

// Tracks an asynchronous bulk receipt-generation request. Progress counters are
// updated as the worker processes matching donations.
model ReceiptBatchJob {
  id             String                @id @default(uuid())
  organizationId String?
  createdBy      String
  status         ReceiptBatchJobStatus @default(PENDING)
  totalCount     Int                   @default(0)
  generatedCount Int                   @default(0)
  failedCount    Int                   @default(0)
  jobMetadata    Json?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  completedAt    DateTime?

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  creator      User          @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdBy])
  @@index([status])
  @@index([createdAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}
