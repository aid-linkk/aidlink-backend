# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database Configuration
DATABASE_URL="postgresql://aidlink:aidlink_password@localhost:5432/aidlink?schema=public"

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Wallet Authentication
WALLET_AUTH_SECRET=your_wallet_auth_secret_change_in_production

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password
EMAIL_FROM=noreply@aidlink.org
EMAIL_QUEUE_ENABLED=false
EMAIL_LOGO_URL=https://aidlink.org/logo.png
SUPPORT_EMAIL=support@aidlink.org
APP_URL=http://localhost:3000

# Soroban/Stellar Configuration
SOROBAN_NETWORK_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
CONTRACT_ADDRESS=your_contract_address

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=logs

# BullMQ Configuration
BULLMQ_REDIS_HOST=localhost
BULLMQ_REDIS_PORT=6379
BULLMQ_REDIS_PASSWORD=

# WebSocket Configuration
WS_PORT=3001

# Monitoring
HEALTH_CHECK_INTERVAL=30000

# Campaign Moderation
# Toggle automatic suspension. Admin manual suspend/reinstate always works.
MODERATION_AUTO_SUSPEND_ENABLED=false
# Suspend campaigns whose verification score stays below the threshold for the grace period.
MODERATION_VERIFICATION_SCORE_THRESHOLD=40
MODERATION_VERIFICATION_GRACE_DAYS=7
# Suspend after N independent fraud reports within the rolling window (hours).
MODERATION_FRAUD_REPORT_THRESHOLD=3
MODERATION_FRAUD_REPORT_WINDOW_HOURS=24
# Notify donors when a campaign is suspended for fraud (set to false to disable).
MODERATION_NOTIFY_DONORS_ON_FRAUD=true

# KYC Fraud Detection
# Velocity window and submission limits
KYC_FRAUD_VELOCITY_WINDOW_MINUTES=60
KYC_FRAUD_VELOCITY_MAX_PER_IP=5
KYC_FRAUD_VELOCITY_MAX_PER_USER=3
# Geographic anomaly: max plausible speed in km/h (commercial flight ~900)
KYC_FRAUD_GEO_MAX_SPEED_KMH=900
# Score threshold to enqueue FRAUD_DETECTION job
KYC_FRAUD_HIGH_RISK_THRESHOLD=50
# Signal weights (integers, loosely sum to 100)
KYC_FRAUD_WEIGHT_DOC_REUSE=30
KYC_FRAUD_WEIGHT_GEO=20
KYC_FRAUD_WEIGHT_VELOCITY=25
KYC_FRAUD_WEIGHT_DEVICE=15
KYC_FRAUD_WEIGHT_THIRD_PARTY=10
# Third-party fraud service (optional, disabled by default)
KYC_FRAUD_THIRD_PARTY_ENABLED=false
KYC_FRAUD_THIRD_PARTY_API_URL=
KYC_FRAUD_THIRD_PARTY_API_KEY=
KYC_FRAUD_THIRD_PARTY_TIMEOUT_MS=5000
